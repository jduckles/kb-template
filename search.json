---
layout: null
permalink: /search.json
---
{% assign searchable = site.articles | where_exp: "a", "a.status != 'draft'" %}
{% assign searchable = searchable | where_exp: "a", "a.standalone != true" %}
[
  {% for article in searchable %}
  {
    "id":          {{ article.url | relative_url | jsonify }},
    "title":       {{ article.title | jsonify }},
    "description": {{ article.description | default: "" | jsonify }},
    "tags":        {{ article.tags | join: " " | jsonify }},
    "content":     {{ article.content | strip_html | strip_newlines | truncate: 5000 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
